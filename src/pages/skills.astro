---
import BaseLayout from '../layouts/BaseLayout.astro';
import { skills, SkillCategories } from '../data/skills';
import AdBanner from '../components/AdBanner.astro';
---

<BaseLayout
  title="Skills 目录 - ClawGuide.dev"
  description="探索 1715+ OpenClaw skills，涵盖 31 个分类。找到适合你 AI 助手的 skill。"
>
  <div class="bg-gradient-to-br from-purple-50 to-white py-12 border-b border-gray-200">
    <div class="container-custom">
      <div class="max-w-3xl">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          OpenClaw Skills 目录
        </h1>
        <p class="text-lg text-gray-600">
          探索 {SkillCategories.reduce((sum, c) => sum + c.count, 0)}+ skills，涵盖 {SkillCategories.length} 个分类
        </p>
      </div>

      <!-- Search -->
      <div class="mt-6 max-w-2xl">
        <input
          type="text"
          id="search-input"
          placeholder="搜索 skills..."
          class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none"
        />
      </div>
    </div>
  </div>

  <div class="container-custom py-8">
    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Categories Sidebar -->
      <aside class="lg:w-72 flex-shrink-0">
        <div class="card p-6 sticky top-24">
          <h2 class="font-bold text-gray-900 mb-4">分类</h2>

          <div class="space-y-1" id="category-filters">
            <button data-category="all" class="filter-btn active flex items-center justify-between px-3 py-2 rounded-lg text-sm w-full">
              <span>全部 Skills</span>
              <span class="text-xs bg-gray-100 px-2 py-0.5 rounded-full">{skills.length}</span>
            </button>
            {SkillCategories.map(cat => (
              <button
                data-category={cat.id}
                class="filter-btn flex items-center justify-between px-3 py-2 rounded-lg text-sm w-full text-gray-600 hover:bg-gray-100"
              >
                <span class="flex items-center">
                  <span class="mr-2">{cat.icon}</span>
                  <span class="truncate">{cat.name}</span>
                </span>
                <span class="text-xs bg-gray-100 px-2 py-0.5 rounded-full flex-shrink-0">{cat.count}</span>
              </button>
            ))}
          </div>
        </div>

        <!-- Sidebar Ad -->
        <AdBanner type="sidebar" />
      </aside>

      <!-- Skills Grid -->
      <div class="flex-1">
        <div id="skills-list" class="grid sm:grid-cols-2 xl:grid-cols-3 gap-4">
          {skills.map((skill) => {
            const cat = SkillCategories.find(c => c.id === skill.category);
            return (
              <div
                class="skill-card card p-5 hover:border-purple-300 transition-all rounded-xl"
                data-category={skill.category}
                data-name={skill.name.toLowerCase()}
                data-desc={skill.description.toLowerCase()}
              >
                <div class="flex items-start justify-between mb-2">
                  <h3 class="font-bold text-gray-900">
                    {skill.name}
                    {skill.verified && (
                      <span class="ml-1 text-green-600" title="已验证 skill">✓</span>
                    )}
                  </h3>
                  <div class="flex items-center text-sm text-gray-500">
                    <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    {skill.popularity}
                  </div>
                </div>
                <p class="text-sm text-gray-600 mb-3 line-clamp-2">{skill.description}</p>
                <div class="flex items-center justify-between">
                  <span class={`inline-flex items-center px-2 py-1 rounded text-xs ${cat?.color || 'bg-gray-100 text-gray-700'}`}>
                    {cat?.icon} {cat?.name}
                  </span>
                  <span class="text-xs text-gray-500">{skill.popularity}%</span>
                </div>
              </div>
            );
          })}
        </div>

        <!-- All Categories Overview -->
        <div class="mt-12 grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4" id="all-categories">
          {SkillCategories.map(cat => (
            <button
              data-category={cat.id}
              class="category-card card p-4 text-center hover:scale-105 transition-transform"
            >
              <div class="text-3xl mb-2">{cat.icon}</div>
              <div class="font-medium text-gray-900 text-sm mb-1">{cat.name}</div>
              <div class="text-xs text-gray-500">{cat.count} skills</div>
            </button>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- All Categories Overview -->
  <section class="bg-gray-50 py-16">
    <div class="container-custom">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">全部分类</h2>
    </div>
  </section>
</BaseLayout>

<style>
  .filter-btn.active {
    background-color: rgb(243 232 255) !important;
    color: rgb(147 51 234) !important;
    font-weight: 600;
  }

  .skill-card[style*="display: none;"] {
    display: none !important;
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script is:inline>
  // 客户端筛选
  function filterSkills() {
    const activeCategory = document.querySelector('#category-filters .filter-btn.active')?.dataset.category || 'all';
    const searchValue = document.getElementById('search-input').value.toLowerCase();
    const skillCards = document.querySelectorAll('.skill-card');

    skillCards.forEach(card => {
      const cardCategory = card.dataset.category;
      const cardName = card.dataset.name || '';
      const cardDesc = card.dataset.desc || '';

      let show = true;

      if (activeCategory !== 'all' && cardCategory !== activeCategory) {
        show = false;
      }

      if (show && searchValue) {
        const matchesSearch = cardName.includes(searchValue) || cardDesc.includes(searchValue);
        if (!matchesSearch) {
          show = false;
        }
      }

      if (show) {
        card.style.display = '';
      } else {
        card.style.display = 'none';
      }
    });
  }

  // 事件绑定
  document.addEventListener('DOMContentLoaded', () => {
    // 分类筛选
    document.getElementById('category-filters')?.addEventListener('click', (e) => {
      const btn = e.target.closest('.filter-btn');
      if (!btn) return;

      document.querySelectorAll('#category-filters .filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      filterSkills();
    });

    // 搜索
    document.getElementById('search-input')?.addEventListener('input', filterSkills);

    // 底部分类卡片
    document.getElementById('all-categories')?.addEventListener('click', (e) => {
      const btn = e.target.closest('.category-card, button');
      if (!btn || !btn.dataset.category) return;

      document.querySelectorAll('#category-filters .filter-btn').forEach(b => b.classList.remove('active'));
      document.querySelector(`#category-filters [data-category="${btn.dataset.category}"]`)?.classList.add('active');
      filterSkills();

      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
</script>
