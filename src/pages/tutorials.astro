---
import BaseLayout from '../layouts/BaseLayout.astro';
import { tutorials, TutorialCategories } from '../data/tutorials';
import AdBanner from '../components/AdBanner.astro';
---

<BaseLayout
  title="教程 - ClawGuide.dev"
  description="浏览 333+ OpenClaw 教程，按分类、语言和来源筛选。"
>
  <div class="bg-gradient-to-br from-primary-50 to-white py-12 border-b border-gray-200">
    <div class="container-custom">
      <div class="max-w-3xl">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          OpenClaw 教程
        </h1>
        <p class="text-lg text-gray-600">
          共 <span id="total-count">{tutorials.length}</span> 个教程
        </p>
      </div>

      <!-- Search -->
      <div class="mt-6 max-w-2xl">
        <input
          type="text"
          id="search-input"
          placeholder="搜索教程..."
          class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none"
        />
      </div>
    </div>
  </div>

  <div class="container-custom py-8">
    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Filters Sidebar -->
      <aside class="lg:w-64 flex-shrink-0">
        <div class="card p-6 sticky top-24">
          <h2 class="font-bold text-gray-900 mb-4">筛选</h2>

          <!-- Category Filter -->
          <div class="mb-6">
            <h3 class="text-sm font-semibold text-gray-700 mb-2">分类</h3>
            <div class="space-y-1" id="category-filters">
              <button data-filter="category" data-value="all" class="filter-btn active w-full text-left px-2 py-1 rounded text-sm bg-primary-100 text-primary-700 font-medium">
                全部分类
              </button>
              {TutorialCategories.map(cat => (
                <button
                  data-filter="category"
                  data-value={cat.id}
                  class="filter-btn w-full text-left px-2 py-1 rounded text-sm text-gray-600 hover:bg-gray-100"
                >
                  <span class="mr-1">{cat.icon}</span> {cat.name}
                </button>
              ))}
            </div>
          </div>

          <!-- Language Filter -->
          <div class="mb-6">
            <h3 class="text-sm font-semibold text-gray-700 mb-2">语言</h3>
            <div class="space-y-1" id="language-filters">
              <button data-filter="language" data-value="all" class="filter-btn active w-full text-left px-2 py-1 rounded text-sm bg-primary-100 text-primary-700 font-medium">
                全部语言
              </button>
              <button data-filter="language" data-value="EN" class="filter-btn w-full text-left px-2 py-1 rounded text-sm text-gray-600 hover:bg-gray-100">
                🇺🇸 English
              </button>
              <button data-filter="language" data-value="中文" class="filter-btn w-full text-left px-2 py-1 rounded text-sm text-gray-600 hover:bg-gray-100">
                🇨🇳 中文
              </button>
            </div>
          </div>

          <button
            id="clear-filters"
            class="block w-full text-center px-4 py-2 border border-gray-300 rounded-lg text-sm text-gray-600 hover:bg-gray-50"
          >
            清除所有筛选
          </button>
        </div>

        <!-- Sidebar Ad -->
        <AdBanner type="sidebar" />
      </aside>

      <!-- Tutorial List -->
      <div class="flex-1">
        <div id="tutorial-list">
          {tutorials.map((tutorial) => {
            const cat = TutorialCategories.find(c => c.id === tutorial.category);
            return (
              <a
                href={tutorial.url}
                target="_blank"
                rel="noopener noreferrer"
                class="tutorial-card card p-6 block hover:border-primary-300 transition-all mb-4"
                data-category={tutorial.category}
                data-language={tutorial.language}
                data-source={tutorial.source}
                data-tags={tutorial.tags.join(',')}
              >
                <div class="flex items-start gap-4">
                  <div class="flex-1">
                    <div class="flex flex-wrap items-center gap-2 mb-2">
                      {tutorial.featured && (
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-800">
                          ⭐ 精选
                        </span>
                      )}
                      <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-gray-100 text-gray-700">
                        {cat?.name || tutorial.category}
                      </span>
                      <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-50 text-blue-700">
                        {tutorial.language}
                      </span>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900 mb-2">
                      {tutorial.title}
                    </h3>
                    <p class="text-gray-600 text-sm mb-3">{tutorial.description}</p>
                    <div class="flex flex-wrap items-center gap-2">
                      <span class="text-xs text-gray-500">来源: {tutorial.source}</span>
                      {tutorial.tags.slice(0, 3).map(tag => (
                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs bg-gray-100 text-gray-600">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  </div>
                  <svg class="w-6 h-6 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .filter-btn.active {
    background-color: rgb(239 246 255) !important;
    color: rgb(37 99 235) !important;
    font-weight: 600;
  }

  .tutorial-card[style*="display: none;"] {
    display: none !important;
  }
</style>

<script is:inline>
  // 客户端筛选逻辑
  const tutorialCards = document.querySelectorAll('.tutorial-card');

  function filterTutorials() {
    const activeCategory = document.querySelector('#category-filters .filter-btn.active')?.dataset.value || 'all';
    const activeLanguage = document.getElementById('language-filters').querySelector('.filter-btn.active')?.dataset.value || 'all';
    const searchValue = document.getElementById('search-input').value.toLowerCase();
    const totalCount = document.getElementById('total-count');

    let visibleCount = 0;

    tutorialCards.forEach(card => {
      const cardCategory = card.dataset.category;
      const cardLanguage = card.dataset.language;
      const cardSource = card.dataset.source;
      const cardTags = card.dataset.tags || '';
      const cardTitle = card.querySelector('h3')?.textContent.toLowerCase() || '';
      const cardDesc = card.querySelector('p')?.textContent.toLowerCase() || '';

      // 筛选逻辑
      let show = true;

      if (activeCategory !== 'all' && cardCategory !== activeCategory) {
        show = false;
      }

      if (show && activeLanguage !== 'all' && cardLanguage !== activeLanguage) {
        show = false;
      }

      if (show && searchValue) {
        const matchesSearch = cardTitle.includes(searchValue) ||
                               cardDesc.includes(searchValue) ||
                               cardTags.includes(searchValue);
        if (!matchesSearch) {
          show = false;
        }
      }

      if (show) {
        card.style.display = '';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });

    totalCount.textContent = visibleCount;
  }

  // 绑定事件
  document.addEventListener('DOMContentLoaded', () => {
    // 分类筛选
    document.getElementById('category-filters')?.addEventListener('click', (e) => {
      const btn = e.target.closest('.filter-btn');
      if (!btn) return;

      document.querySelectorAll('#category-filters .filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      filterTutorials();
    });

    // 语言筛选
    document.getElementById('language-filters')?.addEventListener('click', (e) => {
      const btn = e.target.closest('.filter-btn');
      if (!btn) return;

      document.querySelectorAll('#language-filters .filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      filterTutorials();
    });

    // 搜索
    document.getElementById('search-input')?.addEventListener('input', filterTutorials);

    // 清除筛选
    document.getElementById('clear-filters')?.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      document.querySelector('[data-filter="category"][data-value="all"]')?.classList.add('active');
      document.querySelector('[data-filter="language"][data-value="all"]')?.classList.add('active');
      document.getElementById('search-input').value = '';
      filterTutorials();
    });
  });
</script>
