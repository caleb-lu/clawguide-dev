---
import { getAbsoluteAssetPath } from 'astro:assets';

const navItems = [
  { name: '首页', href: '/' },
  { name: '教程', href: '/tutorials' },
  { name: 'Skills', href: '/skills' },
  { name: '关于', href: '/about' },
];
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50 backdrop-blur-sm bg-white/95">
  <nav class="container-custom">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href={getAbsoluteAssetPath('/')} class="flex items-center space-x-2 group">
        <div class="w-10 h-10 bg-gradient-to-br from-primary-500 to-primary-700 rounded-lg flex items-center justify-center transform group-hover:scale-105 transition-transform">
          <span class="text-white font-bold text-xl">CG</span>
        </div>
        <span class="font-bold text-xl text-gray-900">ClawGuide<span class="text-primary-600">.dev</span></span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-8">
        {navItems.map(item => (
          <a
            href={getAbsoluteAssetPath(item.href)}
            class="text-gray-600 hover:text-primary-600 font-medium transition-colors"
          >
            {item.name}
          </a>
        ))}
        <a href={getAbsoluteAssetPath('/#get-started')} class="btn-primary text-sm">
          开始学习
        </a>
      </div>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg text-gray-600 hover:bg-gray-100">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col space-y-3">
        {navItems.map(item => (
          <a
            href={getAbsoluteAssetPath(item.href)}
            class="text-gray-600 hover:text-primary-600 font-medium py-2"
          >
            {item.name}
          </a>
        ))}
        <a href={getAbsoluteAssetPath('/#get-started')} class="btn-primary text-sm text-center">
          开始学习
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
