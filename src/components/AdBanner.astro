---
import { AD_UNITS, ADSENSE_TEST_MODE } from '../config/adsense';

interface Props {
  type?: 'banner-top' | 'banner-middle' | 'sidebar' | 'content' | 'footer';
  className?: string;
  width?: string;
  height?: string;
}

const {
  type = 'banner-top',
  className = '',
  width = '100%',
  height = '90px'
} = Astro.props;

// 获取广告单元配置
const adUnit = AD_UNITS[type] || AD_UNITS['banner-top'];
const isTestMode = ADSENSE_TEST_MODE;
---

<!-- Ad Banner -->
<div class={`ad-${type} ${className}`} style="width: ${width}">
  {isTestMode ? (
    <!-- 测试模式：显示占位符 -->
    <div
      class="ad-placeholder bg-gradient-to-br from-purple-50 to-blue-50 border-2 border-dashed border-purple-200 rounded-lg flex items-center justify-center text-purple-400 hover:text-purple-500 hover:border-purple-300 transition-all"
      style="min-height: {height}"
    >
      <div class="text-center p-6">
        <div class="text-3xl mb-2">📢</div>
        <div class="text-base font-semibold text-gray-700 mb-1">Google AdSense 广告位</div>
        <div class="text-xs text-gray-500 mb-2">类型: {type}</div>
        <div class="text-xs text-gray-400">
          尺寸: {type === 'sidebar' ? '300x250' : type === 'content' ? '自适应' : '728x90'}
        </div>
        <div class="mt-3 pt-3 border-t border-purple-200">
          <div class="text-xs text-gray-500">
            配置发布商 ID 后将显示真实广告
          </div>
        </div>
      </div>
    </div>
  ) : (
    <!-- 生产模式：显示真实 AdSense 广告 -->
    <div class="adsense-container">
      <ins
        class="adsbygoogle"
        style="display:block"
        data-ad-client={adUnit['data-ad-client']}
        data-ad-slot={adUnit['data-ad-slot']}
        data-ad-format={adUnit['data-ad-format']}
        data-full-width-responsive={adUnit['data-full-width-responsive']}
      ></ins>
    </div>
  )}
</div>

<style>
  .ad-banner-top {
    margin: 1.5rem 0;
  }

  .ad-banner-middle {
    margin: 2rem 0;
  }

  .ad-sidebar {
    margin-bottom: 1.5rem;
  }

  .ad-content {
    margin: 2.5rem 0;
  }

  .ad-footer {
    margin: 2rem 0 0 0;
  }

  .ad-placeholder {
    background: linear-gradient(135deg, #f5f3ff 0%, #dbeafe 100%);
  }

  .adsense-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 90px;
  }

  .adsbygoogle {
    background-color: #f9fafb;
    border-radius: 8px;
  }
</style>

{!isTestMode && (
  <script is:inline>
    (window.adsbygoogle = window.adsbygoogle || []).push({});
  </script>
)}
